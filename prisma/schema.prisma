generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Note {
  id            String     @id @default(cuid())
  title         String
  transcript    String?    @db.Text
  formattedNote String?    @db.Text
  summary       String?    @db.Text
  keywords      String[]
  audioFile     AudioFile?
  status        NoteStatus @default(PROCESSING)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([createdAt])
  @@map("notes")
}

model AudioFile {
  id        String   @id @default(cuid())
  noteId    String   @unique
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  url       String
  fileName  String
  fileSize  Int
  duration  Float
  mimeType  String
  createdAt DateTime @default(now())

  @@map("audio_files")
}

enum NoteStatus {
  PROCESSING
  TRANSCRIBING
  FORMATTING
  COMPLETED
  FAILED
}
